# Todoist API
TODOIST_API_TOKEN=your-todoist-api-token

# AI Models
OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key  # Optional
MODEL_PROVIDER=openai  # openai or openrouter
MODEL_NAME=gpt-4o-mini  # gpt-4o-mini, gpt-4o, etc.

# WhatsApp (Baileys - free self-hosted)
WHATSAPP_SESSION_PATH=./auth  # Persisted WhatsApp auth session

# Redis (optional - for conversation context)
REDIS_URL=redis://localhost:6379

# Legacy: NBN Telegram Bot (if running alongside)
IPERIUM_EMAIL=your-email@example.com
IPERIUM_PASSWORD=your-password
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token